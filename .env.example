PORT=8787
HOST=127.0.0.1
APP_ORIGIN=http://127.0.0.1:8787
SESSION_SECRET=replace-with-a-long-random-secret

# AI provider. The app works without this key using local routing and synthesis,
# but production intelligence should be connected server-side.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1
OPENAI_VISION_MODEL=gpt-4.1
AI_ENDPOINT_STYLE=responses

# Optional live-data providers. Without these, free public fallbacks are used.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
NEWS_API_KEY=
MAPS_API_KEY=

MAX_UPLOAD_MB=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
