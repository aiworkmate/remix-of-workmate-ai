{
  "name": "workmate-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "WorkMate AI full-stack AI operating system with imported AI WorkMate core and GPT module.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/gpt-module"
  ],
  "scripts": {
    "start": "node server/index.mjs",
    "dev": "node server/index.mjs",
    "dev:gpt": "npm run dev -w packages/gpt-module",
    "build": "npm run build -w packages/gpt-module",
    "build:gpt": "npm run build -w packages/gpt-module",
    "test": "node --test tests/*.test.mjs",
    "smoke": "node tests/smoke.mjs",
    "lint": "npm run lint -w packages/gpt-module",
    "format": "npm run format -w packages/gpt-module"
  }
}
